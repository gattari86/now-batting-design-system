{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Now Batting Design Tokens",
    "version": "1.0.0",
    "description": "Light hybrid design system for an outdoor-first baseball walk-up-song app. Neon for moments, daylight for buttons, one rhythm repeated everywhere."
  },
  "color": {
    "background": { "value": "#F6F4EF", "description": "Warm off-white primary canvas. Calm under stadium light." },
    "surface":    { "value": "#FFFFFF", "description": "Cards, sheets, lifted content." },
    "divider":    { "value": "rgba(0,0,0,0.06)", "description": "Hairlines between blocks. Never a hard black border." },
    "text": {
      "primary":   { "value": "#1F1F1F", "description": "Headlines, player names, load-bearing labels." },
      "secondary": { "value": "#4A4A4A", "description": "Body copy, supporting lines." },
      "muted":     { "value": "#6B6B6B", "description": "Metadata, timestamps. Never key info. Passes WCAG AA on white and cream." }
    },
    "accent": {
      "neon":     { "value": "#DFFF00", "description": "Moments only. Active row, waveform, progress. Never on white for body text." },
      "daylight": { "value": "#B8CC00", "description": "Primary buttons. Functional states. Outdoor-legible." }
    },
    "dark": { "value": "#1F1F1F", "description": "Play controls, pullquotes, icon chips, ink." }
  },
  "font": {
    "family": {
      "sans": { "value": "'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif" },
      "mono": { "value": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace" }
    },
    "size": {
      "h1":    { "value": 32, "min": 28, "unit": "px", "description": "Hero statements, major page titles." },
      "h2":    { "value": 22, "min": 20, "unit": "px", "description": "Section headers, song titles on Now Playing." },
      "body":  { "value": 16, "unit": "px", "description": "Main app content. Do not go below this." },
      "small": { "value": 14, "min": 13, "unit": "px", "description": "Metadata, captions, secondary info." },
      "mono":  { "value": 11, "unit": "px", "description": "Labels, eyebrows, numeric callouts." }
    },
    "weight": {
      "regular":  { "value": 400 },
      "medium":   { "value": 500 },
      "semibold": { "value": 600 },
      "bold":     { "value": 700 },
      "black":    { "value": 800 }
    },
    "tracking": {
      "tight":   { "value": "-0.02em", "description": "Display headlines." },
      "display": { "value": "-0.035em", "description": "Hero wordmark scale." },
      "wide":    { "value": "0.18em",  "description": "Mono eyebrows, labels." }
    }
  },
  "radius": {
    "sm": { "value": 8,  "unit": "px" },
    "md": { "value": 12, "unit": "px", "description": "Default button radius." },
    "lg": { "value": 16, "unit": "px", "description": "Default card radius." }
  },
  "spacing": {
    "grid": { "value": 8, "unit": "px", "description": "8pt base grid. Every spacing value is a multiple." },
    "scale": [4, 8, 12, 16, 20, 24, 32, 40, 48, 64]
  },
  "component": {
    "button": {
      "primary": {
        "height":   { "value": 52, "unit": "px" },
        "radius":   { "value": 12, "unit": "px" },
        "bg":       { "value": "{color.accent.daylight}" },
        "text":     { "value": "{color.text.primary}" },
        "fontSize": { "value": 15, "unit": "px" },
        "fontWeight": { "value": 700 }
      },
      "secondary": {
        "height":   { "value": 52, "unit": "px" },
        "radius":   { "value": 12, "unit": "px" },
        "bg":       { "value": "{color.surface}" },
        "border":   { "value": "1px solid rgba(0,0,0,0.13)" },
        "text":     { "value": "{color.text.primary}" }
      }
    },
    "card": {
      "radius": { "value": 16, "unit": "px" },
      "border": { "value": "1px solid {color.divider}" },
      "bg":     { "value": "{color.surface}" }
    },
    "progress": {
      "height": { "value": 5, "min": 4, "max": 6, "unit": "px" },
      "fill":   { "value": "{color.accent.neon}" },
      "track":  { "value": "rgba(0,0,0,0.08)" }
    },
    "touchTarget": {
      "min": { "value": 44, "unit": "px", "description": "Minimum tap target. Gloves-on friendly." }
    },
    "activeRow": {
      "leftBar":    { "value": "4px solid {color.accent.neon}" },
      "bg":         { "value": "{color.surface}" },
      "description": "Tinted row background, neon left bar, dark play button. Never communicate state by color alone."
    }
  },
  "motion": {
    "duration": {
      "fast": { "value": 150, "unit": "ms" },
      "base": { "value": 200, "unit": "ms" },
      "slow": { "value": 250, "unit": "ms" }
    },
    "tap": {
      "scale": { "value": 0.98, "description": "Button press feedback. Physical, not rubbery." }
    }
  },
  "principles": {
    "sunlightFirst":     "Readable at a glance outside. No weak contrast. No tiny text.",
    "momentDriven":      "Neon is the emotional spark. Use it to signal action and status, nothing else.",
    "fastInteraction":   "Primary actions stay obvious and easy to hit with one tap.",
    "lowCognitiveLoad":  "Each screen focuses on one main task, not ten competing ones."
  }
}
